---
interface Props {
  brand: "wrec bench" | "wrec docs";
  current: "benchmarks" | "how" | "docs";
  docsCurrent?: "docs" | "agents" | "architecture" | "configuration";
}

const { brand, current, docsCurrent } = Astro.props;

const navLinks = [
  ["benchmarks", "/benchmarks"],
  ["how", "/benchmarks/how"],
  ["docs", "/docs"],
] as const;

const docsLinks = [
  ["overview", "/docs", "docs"],
  ["agents", "/docs/agents", "agents"],
  ["architecture", "/docs/architecture", "architecture"],
  ["configuration", "/docs/configuration", "configuration"],
] as const;

const activeDocsLink = docsLinks.find(([, , id]) => id === docsCurrent);
---

<header class="site-header">
  <nav class="bench-nav" aria-label="Primary">
    <a class="bench-brand" href={current === "docs" ? "/docs" : "/benchmarks"}
      >{brand}</a
    >
    {
      docsCurrent && (
        <div class="docs-topbar-tools">
          <div class="docs-dropdown" data-docs-dropdown>
            <button
              type="button"
              class="docs-dropdown-trigger"
              aria-expanded="false"
              aria-haspopup="menu"
              data-docs-dropdown-trigger
            >
              <span>{activeDocsLink?.[0]}</span>
              <span class="docs-dropdown-caret" aria-hidden="true">
                ▾
              </span>
            </button>
            <nav
              class="docs-dropdown-menu t-dropdown"
              data-origin="top-left"
              data-docs-dropdown-menu
              aria-label="Documentation"
            >
              {docsLinks.map(([name, href, id]) => (
                <a
                  href={href}
                  class="docs-nav-link"
                  role="menuitem"
                  data-current={docsCurrent === id ? "true" : "false"}
                  aria-current={docsCurrent === id ? "page" : "false"}
                >
                  {name}
                </a>
              ))}
            </nav>
          </div>
          <button
            type="button"
            class="copy-button copy-page-button"
            data-copy-page
            data-label="Copy page"
            aria-label="Copy page"
            title="Copy page"
          >
            <svg
              class="copy-default"
              viewBox="0 0 256 256"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="18"
            >
              <path d="M168 168h48V40H88v48" />
              <rect x="40" y="88" width="128" height="128" rx="8" />
            </svg>
            <svg
              class="copy-success"
              viewBox="0 0 256 256"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="20"
            >
              <path d="M40 144l56 56L216 72" />
            </svg>
            <span>copy page</span>
          </button>
        </div>
      )
    }
    <div class="bench-nav-links">
      {
        navLinks.map(([name, href]) => (
          <a
            href={href}
            class="bench-nav-link"
            data-current={current === name ? "true" : "false"}
            aria-current={current === name ? "page" : "false"}
          >
            {name}
          </a>
        ))
      }
      <button
        type="button"
        class="theme-toggle bench-theme-toggle"
        data-theme-toggle
        aria-label="Use dark theme"
      >
        dark
      </button>
    </div>
  </nav>
</header>
