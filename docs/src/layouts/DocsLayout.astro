---
import { Font } from "astro:assets";
import "../styles/global.css";

interface Props {
  title: string;
  current: "docs" | "agents" | "architecture" | "configuration" | "benchmarks";
}

const { title, current } = Astro.props;

const navLinks = [
  ["docs", "/docs"],
  ["agents", "/docs/agents"],
  ["architecture", "/docs/architecture"],
  ["configuration", "/docs/configuration"],
  ["benchmarks", "/benchmarks"],
] as const;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/wrec.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-departure" preload />
    <script defer src="https://assets.onedollarstats.com/stonks.js"></script>
    <script is:inline>
      (() => {
        const themeKey = "wrec-theme";
        const isTheme = (value) => value === "light" || value === "dark";
        const readTheme = () => {
          try {
            const stored = localStorage.getItem(themeKey);
            return isTheme(stored) ? stored : "light";
          } catch {
            return "light";
          }
        };
        const writeTheme = (theme) => {
          try {
            localStorage.setItem(themeKey, theme);
          } catch {}
        };
        const applyTheme = (theme) => {
          document.documentElement.dataset.theme = theme;
        };
        const currentTheme = () =>
          document.documentElement.dataset.theme === "dark" ? "dark" : "light";
        const labelThemeButton = (button) => {
          const next = currentTheme() === "dark" ? "light" : "dark";
          button.textContent = next;
          button.setAttribute("aria-label", `Use ${next} theme`);
        };

        applyTheme(readTheme());

        const copy = async (button, text) => {
          await navigator.clipboard.writeText(text.trim());
          button.dataset.copied = "true";
          button.setAttribute("aria-label", "Copied");
          window.setTimeout(() => {
            delete button.dataset.copied;
            button.setAttribute("aria-label", button.dataset.label || "Copy");
          }, 1200);
        };

        window.addEventListener("DOMContentLoaded", () => {
          document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
            labelThemeButton(button);
            button.addEventListener("click", () => {
              const next = currentTheme() === "dark" ? "light" : "dark";
              applyTheme(next);
              writeTheme(next);
              labelThemeButton(button);
            });
          });

          document.querySelectorAll("[data-copy-button]").forEach((button) => {
            button.addEventListener("click", () => {
              const target = button.closest("[data-copy-block]");
              const text = target?.querySelector("code")?.textContent ?? "";
              copy(button, text);
            });
          });

          document
            .querySelector("[data-copy-page]")
            ?.addEventListener("click", (event) => {
              const button = event.currentTarget;
              const content = document
                .querySelector("[data-docs-content]")
                ?.cloneNode(true);
              content
                ?.querySelectorAll("[data-copy-button]")
                .forEach((node) => node.remove());
              copy(button, content?.textContent ?? "");
            });
        });
      })();
    </script>
    <title>{title}</title>
  </head>
  <body class="docs-page">
    <main>
      <nav class="docs-actions" aria-label="Primary">
        <div class="docs-nav">
          {
            navLinks.map(([name, href]) => (
              <a
                href={href}
                class="docs-nav-link"
                data-current={current === name ? "true" : "false"}
                aria-current={current === name ? "page" : "false"}
              >
                {name}
              </a>
            ))
          }
        </div>
        <div class="docs-action-group">
          <button
            type="button"
            class="theme-toggle docs-theme-toggle"
            data-theme-toggle
            aria-label="Use dark theme"
          >
            dark
          </button>
          <button
            type="button"
            class="copy-button copy-page-button"
            data-copy-page
            data-label="Copy page"
            aria-label="Copy page"
            title="Copy page"
          >
            <svg
              class="copy-default"
              viewBox="0 0 256 256"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="18"
            >
              <path d="M168 168h48V40H88v48"></path>
              <rect x="40" y="88" width="128" height="128" rx="8"></rect>
            </svg>
            <svg
              class="copy-success"
              viewBox="0 0 256 256"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="20"
            >
              <path d="M40 144l56 56L216 72"></path>
            </svg>
            <span>copy page</span>
          </button>
        </div>
      </nav>

      <article data-docs-content>
        <slot />
      </article>
    </main>
  </body>
</html>
