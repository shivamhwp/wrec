---
import { Font } from "astro:assets";
import Seo from "../components/Seo.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/wrec.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <Seo
      title="wrec"
      description="The efficient, agent-native screen recorder for macOS."
    />
    <Font cssVariable="--font-departure" preload />
    <script defer src="https://assets.onedollarstats.com/stonks.js"></script>
    <title>wrec</title>
  </head>
  <body class="m-0 overflow-hidden select-none">
    <main class="home-red" aria-label="wrec">
      <header class="home-bar">
        <span>
          made by&nbsp;<a
            href="https://shivam.ing"
            target="_blank"
            rel="noopener noreferrer">shivam</a
          >
        </span>
        <span class="home-bar-links">
          <a href="/benchmarks">benchmarks</a>
          <a href="/docs">docs</a>
        </span>
      </header>
      <div class="home-logo-stage is-playing" data-logo-animation>
        <svg
          class="home-logo-svg"
          viewBox="0 0 560 240"
          role="img"
          aria-label="wrec"
        >
          <g class="logo-word">
            <text x="280" y="170" text-anchor="middle">wrec</text>
          </g>

          <g class="camera-person" aria-hidden="true">
            <g class="runner-body">
              <rect x="0" y="-34" width="14" height="14"></rect>
              <rect x="2" y="-20" width="12" height="25"></rect>
              <rect x="-5" y="-16" width="8" height="20"></rect>
              <rect
                class="runner-leg runner-leg-back"
                x="7"
                y="4"
                width="7"
                height="22"></rect>
              <rect
                class="runner-leg runner-leg-front"
                x="1"
                y="4"
                width="7"
                height="22"></rect>

              <g class="film-camera">
                <path d="M12-31h6v-4h8v4h5v13H12z"></path>
                <path d="M31-28h8v7h-8z"></path>
                <path class="camera-reel camera-reel-left" d="M13-38h8v-8h-8z"
                ></path>
                <path class="camera-reel camera-reel-right" d="M23-38h8v-8h-8z"
                ></path>
                <rect x="18" y="-18" width="4" height="8"></rect>
              </g>
            </g>
          </g>
        </svg>
        <button
          class="logo-replay"
          type="button"
          data-logo-replay
          aria-label="Replay logo animation"
          title="Replay animation"
        >
          ↻
        </button>
      </div>
    </main>
    <script>
      const stage = document.querySelector("[data-logo-animation]");
      document
        .querySelector("[data-logo-replay]")
        ?.addEventListener("click", () => {
          stage?.classList.remove("is-playing");
          if (stage instanceof HTMLElement) void stage.offsetWidth;
          stage?.classList.add("is-playing");
        });
    </script>
  </body>
</html>

<style>
  .home-red {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    padding: 0 16px;
    box-sizing: border-box;
    background: var(--wrec-red);
    font-family: var(--font-departure), monospace;
  }

  .home-bar-links {
    display: inline-flex;
    gap: 18px;
  }

  .home-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 5px 0 4px;
    font-size: 0.875rem;
    color: #fff;
  }

  .home-bar a {
    color: #fff;
    text-decoration: none;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    font-weight: 600;
  }

  .home-bar a:hover,
  .home-bar a:focus-visible {
    text-decoration: underline;
  }

  .home-logo-stage {
    position: relative;
    flex: 1;
    min-height: 0;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-logo-svg {
    display: block;
    width: min(100%, 560px);
    height: auto;
    overflow: visible;
  }

  .logo-word {
    transform-box: fill-box;
    transform-origin: center;
  }

  .logo-word text {
    font-family: var(--font-departure), monospace;
    font-size: 92px;
    font-weight: 700;
    fill: #0d0d0d;
  }

  .camera-person {
    fill: #0d0d0d;
    transform: translate(-80px, 135px);
    transform-origin: 0 0;
  }

  .runner-body,
  .runner-leg,
  .camera-reel {
    transform-box: fill-box;
  }

  .runner-body {
    transform-origin: center bottom;
  }

  .runner-leg {
    transform-origin: center top;
  }

  .camera-reel {
    transform-origin: center;
  }

  .is-playing .camera-person {
    animation: camera-jump 6.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .is-playing .runner-body {
    animation: runner-bob 360ms steps(2, end) 8;
  }

  .is-playing .runner-leg-front {
    animation: leg-front 360ms steps(2, end) 8;
  }

  .is-playing .runner-leg-back {
    animation: leg-back 360ms steps(2, end) 8;
  }

  .is-playing .camera-reel-left {
    animation: reel-spin 480ms steps(4, end) 7;
  }

  .is-playing .camera-reel-right {
    animation: reel-spin 480ms steps(4, end) 7 reverse;
  }

  .is-playing .logo-word {
    animation: word-land 6.2s ease-out both;
  }

  .logo-replay {
    position: absolute;
    left: 50%;
    top: calc(50% + 88px);
    translate: -50% 0;
    padding: 6px;
    border: 0;
    background: transparent;
    color: #0d0d0d;
    font:
      700 20px/1 var(--font-departure),
      monospace;
    cursor: pointer;
    opacity: 0;
    transform: scale(0.98);
    transition:
      opacity 150ms ease-out,
      transform 150ms ease-out;
  }

  .home-logo-stage:hover .logo-replay,
  .home-logo-stage:focus-within .logo-replay {
    opacity: 0.7;
    transform: scale(1);
  }

  .logo-replay:hover,
  .logo-replay:focus-visible {
    opacity: 1;
    outline: none;
  }

  @keyframes camera-jump {
    0%,
    8% {
      transform: translate(-80px, 135px);
    }
    18% {
      transform: translate(22px, 135px);
    }
    28% {
      transform: translate(100px, 92px) rotate(-7deg);
    }
    43% {
      transform: translate(220px, 30px) rotate(2deg);
    }
    56% {
      transform: translate(332px, 76px) rotate(7deg);
    }
    64% {
      transform: translate(398px, 135px) rotate(0deg);
    }
    69% {
      transform: translate(421px, 127px) rotate(-2deg);
    }
    76% {
      transform: translate(462px, 135px);
    }
    100% {
      transform: translate(640px, 135px);
    }
  }

  @keyframes runner-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-3px);
    }
  }

  @keyframes leg-front {
    0%,
    100% {
      transform: rotate(24deg);
    }
    50% {
      transform: rotate(-24deg);
    }
  }

  @keyframes leg-back {
    0%,
    100% {
      transform: rotate(-24deg);
    }
    50% {
      transform: rotate(24deg);
    }
  }

  @keyframes reel-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes word-land {
    0%,
    57% {
      transform: translateY(0) scale(1);
    }
    63% {
      transform: translateY(4px) scale(1.04, 0.92);
    }
    69% {
      transform: translateY(-2px) scale(0.98, 1.03);
    }
    76%,
    100% {
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .camera-person {
      display: none;
    }

    .logo-word,
    .runner-body,
    .runner-leg,
    .camera-reel {
      animation: none !important;
    }

    .logo-replay {
      display: none;
    }
  }
</style>
