---
import { Font } from "astro:assets";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/wrec.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-geist" preload />
    <Font cssVariable="--font-departure" preload />
    <script defer src="https://assets.onedollarstats.com/stonks.js"></script>
    <title>wrec</title>
  </head>
  <body class="m-0 overflow-hidden select-none">
    <main class="home-red" aria-label="wrec">
      <header class="home-bar">
        <span>
          made by&nbsp;<a
            href="https://shivam.ing"
            target="_blank"
            rel="noopener noreferrer">shivam</a
          >
        </span>
        <span class="home-bar-links">
          <a href="/benchmarks">benchmarks</a>
          <a href="/docs">docs</a>
        </span>
      </header>
      <svg
        class="home-word home-word-horizontal"
        viewBox="2 -55.2 247.9 56.4"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <text x="0" y="0" font-size="100">wrec</text>
      </svg>
      <svg
        class="home-word home-word-vertical"
        viewBox="-1.2 2 56.4 247.9"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <text x="0" y="0" font-size="100" transform="rotate(90)">wrec</text>
      </svg>
    </main>
  </body>
</html>

<style>
  .home-red {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    background: #c62828;
    /* Departure Mono is wrec's voice everywhere; only the giant wordmark
       below stays Geist. */
    font-family: var(--font-departure), monospace;
  }

  .home-bar-links {
    display: inline-flex;
    gap: 18px;
  }

  .home-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 5px 24px 4px;
    font-size: 0.875rem;
    color: #fff;
  }

  .home-bar a {
    color: #fff;
    text-decoration: none;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    font-weight: 600;
  }

  .home-bar a:hover,
  .home-bar a:focus-visible {
    text-decoration: underline;
  }

  .home-word {
    flex: 1;
    min-height: 0;
    width: 100%;
    display: block;
  }

  .home-word text {
    font-family: var(--font-geist), sans-serif;
    font-weight: 900;
    fill: #0d0d0d;
  }

  .home-word-vertical {
    display: none;
  }

  @media (max-width: 700px) and (orientation: portrait) {
    .home-word-horizontal {
      display: none;
    }

    .home-word-vertical {
      display: block;
    }
  }
</style>
