---
import { Font } from "astro:assets";

interface Props {
  body?: boolean;
  mono?: boolean;
}

const { body = false, mono = false } = Astro.props;
---

<Font cssVariable="--font-clash-grotesk" preload={true} />
{body && <Font cssVariable="--font-geist" preload={true} />}
{mono && <Font cssVariable="--font-geist-mono" preload={true} />}
